generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  connection = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?

  source    String   @default("meta")
  status    String   @default("NEW")
  score     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Property {
  id           String   @id @default(cuid())
  title        String
  neighborhood String?
  city         String   @default("São Paulo")
  price        Float?
  area         Float?
  description  String?

  createdAt    DateTime @default(now())
}
